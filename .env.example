# Copy this file to `.env` and fill in your own API keys.
# The Discover/download module reads these values at runtime via flutter_dotenv.

# Last.fm API key — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# YouTube Data API v3 key — https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# RapidAPI key (subscribed to youtube-mp36) — https://rapidapi.com/
RAPIDAPI_KEY=
